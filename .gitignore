# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Model checkpoints
*.pth
*.pt
*.ckpt

# Data artifacts (keep directory placeholders)
data/synthetic/images/**
data/synthetic/train/**
data/synthetic/val/**
data/synthetic/test/**
data/synthetic/*_labels.txt
data/synthetic/all_labels.txt
data/uploads/*
!data/uploads/.gitkeep
data/real/images/*
!data/real/images/.gitkeep
# Keep the small Kanyawee poem crops + labels in git (demo / thesis reproducibility)
!data/real/images/poem_line_*.png
data/real/images_aug/
data/real/labels/*
!data/real/labels/.gitkeep
!data/real/labels/poem_kanyawee.txt
!data/real/labels/user_batch1.txt
!data/real/labels/user_batch1_holdout.txt
!data/real/labels/user_batch1_gt.json
# poem_kanyawee_aug.txt / user_batch1_aug.txt are regenerated locally (images_aug/ is large / gitignored)
# Keep a few example user_batch1 crops for demo reproducibility (not full pages/)
!data/real/images/user_p01_line_*.png
!data/real/images/user_p02_line_*.png
!data/real/images/user_p05_line_*.png
!data/real/images/user_p11_line_*.png
# Full pages stay local (may be large); inventory is small and tracked
!data/real/pages/user_batch1/INVENTORY.md
!data/real/pages/user_batch1/inventory.json

data/debug/*
!data/debug/.gitkeep
data/raw/**
data/preprocessed/**
data/synthetic_pages/**
data/eval_pages/**
data/eval_real/**
data/synthetic_sample/**
!data/.gitkeep
!data/real/.gitkeep
!data/synthetic/train/.gitkeep
!data/synthetic/val/.gitkeep
!data/synthetic/test/.gitkeep

models/*
!models/.gitkeep
!models/charset.json

# Downloaded font files (fetched via scripts/download_fonts.ps1, not committed)
fonts/*.ttf
fonts/*.ttc

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
runs/



data/real/pages/**/*.png

